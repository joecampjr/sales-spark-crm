// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  branches  Branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  city      String
  state     String
  address   String?
  phone     String?
  email     String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellers   Seller[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hash da senha
  role      String   @default("VENDEDOR") // ADMIN, SUPERVISOR, GERENTE, VENDEDOR
  
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seller {
  id             String   @id @default(uuid())
  name           String
  email          String?  @unique
  phone          String?
  avatar         String?
  region         String
  status         String   @default("ativo")
  commissionRate Float    @default(0.0)
  
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  
  salesCount     Int      @default(0)
  conversionRate Float    @default(0.0)
  activeLeads    Int      @default(0)
  contactsToday  Int      @default(0)
  contactsTarget Int      @default(10)
  monthlyGoal    Float    @default(0.0)
  
  leads          Lead[]
  interactions   Interaction[]
  visits         Visit[]
  salesActions   SalesActionStaff[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String   @unique
  city           String
  state          String
  status         String
  priority       String
  estimatedValue Float?
  source         String
  sellerId       String?
  seller         Seller?  @relation(fields: [sellerId], references: [id])
  interactions   Interaction[]
  visits         Visit[]
  actionLeads    SalesActionLead[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Interaction {
  id           String    @id @default(uuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type         String
  result       String
  notes        String?
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Visit {
  id             String    @id @default(uuid())
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sellerId       String
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  address        String
  visitDate      DateTime
  status         String
  notes          String?
  authorizedById String?
  authorizedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SalesAction {
  id              String    @id @default(uuid())
  title           String
  region          String
  startDate       DateTime
  endDate         DateTime
  salesTarget     Float     @default(0)
  status          String
  observations    String?
  
  staffCount      Int       @default(0)
  staff           SalesActionStaff[]
  targetLeads     SalesActionLead[]
  
  reportContent   String?
  reportResult    String?
  reportSubmittedAt DateTime?
  
  authorizedById  String?
  authorizedAt    DateTime?
  
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SalesActionStaff {
  id            String      @id @default(uuid())
  salesActionId String
  salesAction   SalesAction @relation(fields: [salesActionId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model SalesActionLead {
  id            String      @id @default(uuid())
  salesActionId String
  salesAction   SalesAction @relation(fields: [salesActionId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  result        String?
  feedback      String?
}

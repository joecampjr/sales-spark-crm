// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Seller {
  id             String   @id @default(uuid())
  name           String
  region         String
  salesCount     Int      @default(0)
  conversionRate Float    @default(0.0)
  activeLeads    Int      @default(0)
  contactsToday  Int      @default(0)
  contactsTarget Int      @default(10)
  monthlyGoal    Float    @default(0.0)
  leads          Lead[]
  interactions   Interaction[]
  visits         Visit[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String   @unique
  city           String
  state          String
  status         String
  priority       String
  estimatedValue Float?
  source         String
  sellerId       String?
  seller         Seller?  @relation(fields: [sellerId], references: [id])
  interactions   Interaction[]
  visits         Visit[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Interaction {
  id           String    @id @default(uuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type         String    // ligacao, whatsapp, email, visita
  result       String    // interessado, sem resposta, venda_fechada, etc
  notes        String?
  scheduledFor DateTime? // Data de retorno agendada
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Visit {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  address     String
  visitDate   DateTime
  status      String   // agendada, realizada, cancelada, remarcada
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
